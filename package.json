{
  "name": "chrishicks-ca",
  "private": true,
  "devDependencies": {
    "ajv": "8.12.0",
    "ajv-cli": "5.0.0",
    "ajv-formats": "^2.1.1"
  },
  "scripts": {
    "validate": "node validate.js",
    "validate:instance": "node validate.js",
